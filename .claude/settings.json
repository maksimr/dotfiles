{
  "effortLevel": "high",
  "theme": "dark-ansi",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git blame *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ps *)",
      "Bash(tree *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(uname *)",
      "Bash(date)",
      "Bash(jq *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(npm:*)",
      "Bash(uv init *)",
      "Bash(uv add *)",
      "Bash(uv run *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(sudo *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./.ssh/**)",
      "Edit(//System/**)",
      "Edit(//Library/**)",
      "Edit(//private/**)",
      "Edit(//usr/**)",
      "Edit(//bin/**)",
      "Edit(//sbin/**)",
      "Edit(//etc/**)",
      "Edit(//var/**)",
      "Edit(//Users/*/Library/**)",
      "Edit(//boot/**)",
      "Edit(//proc/**)",
      "Edit(//sys/**)",
      "Edit(//dev/**)",
      "Edit(//root/**)",
      "Edit(//run/**)",
      "Edit(//lib/**)",
      "Edit(//lib64/**)",
      "Edit(//opt/**)",
      "Edit(//srv/**)",
      "Write(//System/**)",
      "Write(//Library/**)",
      "Write(//private/**)",
      "Write(//usr/**)",
      "Write(//bin/**)",
      "Write(//sbin/**)",
      "Write(//etc/**)",
      "Write(//var/**)",
      "Write(//Users/*/Library/**)",
      "Write(//boot/**)",
      "Write(//proc/**)",
      "Write(//sys/**)",
      "Write(//dev/**)",
      "Write(//root/**)",
      "Write(//run/**)",
      "Write(//lib/**)",
      "Write(//lib64/**)",
      "Write(//opt/**)",
      "Write(//srv/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/claude-notify.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/claude-notify.sh" }
        ]
      }
    ]
  }
}
